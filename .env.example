# Session secret (required) - minimum 32 characters
NUXT_SESSION_PASSWORD=your-super-secret-session-password-min-32-chars

# GitHub OAuth (required for admin login)
NUXT_OAUTH_GITHUB_CLIENT_ID=your-github-client-id
NUXT_OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# Access roles (comma-separated GitHub logins). Owners & editors see drafts/private
# decks and reach the admin area; any other authenticated login is a viewer
# (public-only rights). If both lists are empty, NO ONE is privileged.
NUXT_OWNER_LOGINS=your-github-login
NUXT_EDITOR_LOGINS=

# Private presentations repository sync (optional, used on Vercel)
# GitHub repo containing private presentations (format: "owner/repo")
PRESENTATIONS_REPO=ShallowRed/nuxt-slides-content
# GitHub Personal Access Token with repo read access
PRESENTATIONS_REPO_TOKEN=
# Branch to sync from (default: main)
PRESENTATIONS_BRANCH=main
# Folders to sync (comma-separated, default: private,semi-private,draft)
PRESENTATIONS_FOLDERS=private,semi-private,draft
