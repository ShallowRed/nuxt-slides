{
  "name": "nuxt-slides",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm build:themes && nuxt dev",
    "dev:theme": "node scripts/build-themes.js --watch",
    "prebuild": "node scripts/fetch-presentations.js",
    "build": "pnpm build:themes && nuxt build",
    "build:themes": "node scripts/build-theme-tokens.ts && node scripts/build-themes.js",
    "build:theme": "node scripts/build-themes.js",
    "pregenerate": "node scripts/fetch-presentations.js",
    "generate": "pnpm build:themes && nuxt generate",
    "preview": "nuxt preview",
    "preview:static": "pnpm generate && nuxt preview",
    "prepare": "nuxt prepare",
    "hash-password": "node scripts/hash-password.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@iconify/vue": "catalog:",
    "@nuxtjs/mdc": "catalog:",
    "@types/node": "catalog:",
    "js-yaml": "catalog:",
    "mermaid": "catalog:",
    "nuxt": "catalog:",
    "nuxt-auth-utils": "catalog:",
    "reveal.js": "catalog:",
    "unist-util-visit": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@iconify-json/ri": "catalog:",
    "@nuxt/icon": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/js-yaml": "catalog:",
    "concurrently": "catalog:",
    "daisyui": "catalog:",
    "eslint": "catalog:",
    "sass": "catalog:",
    "tailwindcss": "catalog:",
    "vitest": "catalog:"
  }
}
