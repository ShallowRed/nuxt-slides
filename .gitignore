# Nuxt dev/build outputs
.output
.data
.nuxt
.nitro
.cache
dist

# Node dependencies
node_modules

# Logs
logs
*.log

# Misc
.DS_Store
.fleet
.idea

# Local env files
.env
.env.*
!.env.example

# Exports (may contain sensitive content)
export/*
!export/.gitkeep

# Temporary clone directory for fetching presentations
.presentations-temp

# Standalone bundle artifacts
dist-standalone/
presentations/public/_storybook-bundle/
presentations/public/*--standalone.md

# Frozen-presentation hosting (DDR-018). GENERATED by `make freeze-presentation`
# and served as-is by Nitro (nuxt.config publicAssets). Kept OUTSIDE public/ so
# `nuxt generate` never aspirates an already-frozen bundle into the next one.
#
# These are COMMITTED on purpose: Vercel builds from Git and serves them via
# publicAssets, so /p/<alias> → /frozen/<alias>/ resolves in production. They were
# previously ignored, which 404'd every frozen deck in prod. Regenerating them at
# build time isn't viable (needs Storybook + the source notes), so a frozen deck —
# which by definition rarely changes — is versioned as the deployable artefact.
.vercel
.env*
