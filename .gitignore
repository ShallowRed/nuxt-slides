# Nuxt dev/build outputs
.output
.data
.nuxt
.nitro
.cache
dist

# Node dependencies
node_modules

# Logs
logs
*.log

# Misc
.DS_Store
.fleet
.idea

# Local env files
.env
.env.*
!.env.example

# Exports (may contain sensitive content)
export/*
!export/.gitkeep

# Temporary clone directory for fetching presentations
.presentations-temp

# Standalone bundle artifacts
dist-standalone/
presentations/public/_storybook-bundle/
presentations/public/*--standalone.md

# Frozen-presentation hosting (DDR-018). GENERATED by `make freeze-presentation`
# and served as-is by Nitro (nuxt.config publicAssets). Build artefacts, not repo
# source — and crucially OUTSIDE public/ so `nuxt generate` never aspirates an
# already-frozen bundle (or its mirrored assets) into the next one.
.frozen/
.frozen-mirror/
.vercel
.env*
